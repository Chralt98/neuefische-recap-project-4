meta {
  name: Login Seller
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "felix",
    "password": "1234"
  }
}

script:post-response {
  if (res.getStatus() === 200) {
    bru.setEnvVar("sellerToken", res.getBody().access_token);
  }
}

docs {
  Logs the seller in and stores the JWT in the `sellerToken` environment
  variable, which "Create Auction" reads automatically.
}
